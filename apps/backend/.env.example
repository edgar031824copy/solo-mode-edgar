# Backend environment variables
# Copy to .env for local development. Never commit .env.

# ─── Database ─────────────────────────────────────────────────────────────────
# Local: postgresql://user:password@localhost:5432/recruitment
# Production (Supabase): postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/recruitment

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-secret

# ─── Anthropic API ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-placeholder

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local: http://localhost:5173
# Production: https://<cloudfront-id>.cloudfront.net (or your custom domain)
CORS_ORIGIN=http://localhost:5173

# ─── S3 Uploads (F-24) ────────────────────────────────────────────────────────
# Production values are provisioned by Terraform (infrastructure/terraform/).
# For local dev: leave empty (upload tests use mocks).
AWS_UPLOADS_BUCKET=
AWS_REGION=us-east-1
# Note: deploy.yml writes BACKEND_S3_* names (not standard AWS_* names) so the SDK
# credential chain cannot auto-resolve them. s3.service.ts reads these explicitly.
BACKEND_S3_ACCESS_KEY_ID=
BACKEND_S3_SECRET_ACCESS_KEY=
