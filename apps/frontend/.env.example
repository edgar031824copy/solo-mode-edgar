# Frontend environment variables
# Copy to .env.local for local development. Never commit .env.local.
# Vite bakes these values into the static bundle at build time.

# ─── API Base URL ─────────────────────────────────────────────────────────────
# Local: http://localhost:3000 (Vite proxies /api/* to the backend — see vite.config.ts)
# Production: https://<cloudfront-id>.cloudfront.net
#   (CloudFront /api/* behavior forwards to Lightsail — same domain, no CORS needed)
VITE_API_URL=http://localhost:3000
